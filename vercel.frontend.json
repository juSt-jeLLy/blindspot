{
  "version": 2,
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "buildCommand": "npm run build:frontend",
        "distDir": "dist-frontend"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "status": 404, "dest": "/index.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
